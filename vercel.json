{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/chat.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.py"
    },
    {
      "src": "/api/chat-stream",
      "dest": "/api/chat.py"
    },
    {
      "src": "/api/health",
      "dest": "/api/chat.py/health"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
